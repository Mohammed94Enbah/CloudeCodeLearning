{
  "permissions": {
    "allow": [
      "Bash(git push *)",
      "Bash(git add *)",
      "Bash(npx --yes prettier --write \"**/*.{ts,tsx,css,json}\" --ignore-path .gitignore)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "echo \"hello\""
          },
          {
            "type": "command",
            "command": "$raw = [Console]::In.ReadToEnd(); $j = $raw | ConvertFrom-Json; $f = $j.tool_input.file_path; if ($f -and (Test-Path $f)) { npx --yes prettier --write $f --ignore-unknown }; exit 0",
            "shell": "powershell",
            "statusMessage": "Running Prettier..."
          }
        ]
      }
    ]
  }
}
